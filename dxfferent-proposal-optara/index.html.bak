  var pageConfirm = document.getElementById('page-confirm');
  var checkbox = document.getElementById('accept-check');
  var btnAccept = document.getElementById('btn-accept');
  var form = document.getElementById('acceptance-form');
  var formWrapper = document.getElementById('acceptance-form-wrapper');
  var successEl = document.getElementById('acceptance-success');

  document.getElementById('form-next').value = window.location.href.split('#')[0] + '#accepted';

  window.selectService = function() {
    pageQuote.classList.add('hidden');
    pageConfirm.classList.remove('hidden');
    window.scrollTo({ top: 0, behavior: 'smooth' });
  };

  window.goBack = function() {
    pageConfirm.classList.add('hidden');
    pageQuote.classList.remove('hidden');
    window.scrollTo({ top: 0, behavior: 'smooth' });
  };

  checkbox.addEventListener('change', function() {
    if (this.checked) {
      btnAccept.disabled = false;
      btnAccept.classList.add('enabled');
    } else {
      btnAccept.disabled = true;
      btnAccept.classList.remove('enabled');
    }
  });

  form.addEventListener('submit', function(e) {
    e.preventDefault();
    btnAccept.textContent = 'Sending...';
    btnAccept.disabled = true;

    fetch(form.action, {
      method: 'POST',
      body: new FormData(form),
      headers: { 'Accept': 'application/json' }
    }).then(function(r) {
      if (r.ok) {
        formWrapper.classList.add('hidden');
        successEl.classList.remove('hidden');
      } else {
        form.submit();
      }
    }).catch(function() {
      form.submit();
    });
  });

  if (window.location.hash === '#accepted') {
    formWrapper.classList.add('hidden');
    successEl.classList.remove('hidden');
  }
})();
</script>
</body>
</html>
